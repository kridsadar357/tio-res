import 'dart:io';
import 'dart:typed_data';
import 'package:blue_thermal_printer/blue_thermal_printer.dart';
import 'package:flutter/foundation.dart';
import 'package:permission_handler/permission_handler.dart';
import 'printer_adapter.dart';

/// Adapter for Bluetooth Thermal Printers (Android only)
class BluetoothPrinterAdapter implements PrinterAdapter {
  final BlueThermalPrinter _bluetooth = BlueThermalPrinter.instance;
  BluetoothDevice? _connectedDevice;
  bool _isConnected = false;

  /// Check and request permissions
  Future<bool> checkPermissions() async {
    if (!Platform.isAndroid) return false;

    final status = await [
      Permission.bluetoothScan,
      Permission.bluetoothConnect,
      Permission.bluetooth,
      Permission.bluetoothAdvertise,
    ].request();

    return status.values.every((permission) => permission.isGranted);
  }

  /// Scan for bonded devices
  Future<List<BluetoothDevice>> scanDevices() async {
    if (!Platform.isAndroid) return [];
    try {
      return await _bluetooth.getBondedDevices();
    } catch (e) {
      debugPrint('Error scanning bluetooth devices: $e');
      return [];
    }
  }

  @override
  Future<bool> connect(String identifier) async {
    if (!Platform.isAndroid) return false;

    try {
      // If already connected to this device, return true
      if (_isConnected && _connectedDevice?.address == identifier) {
        return true;
      }

      // Find device by address (identifier)
      final devices = await scanDevices();
      final device = devices.firstWhere(
        (d) => d.address == identifier,
        orElse: () => throw Exception('Device not found'),
      );

      // Connect
      final success = await _bluetooth.connect(device) ?? false;
      if (success) {
        _isConnected = true;
        _connectedDevice = device;
        return true;
      }
      return false;
    } catch (e) {
      debugPrint('Error connecting to bluetooth printer: $e');
      return false;
    }
  }

  @override
  Future<void> disconnect() async {
    if (!Platform.isAndroid) return;
    try {
      await _bluetooth.disconnect();
      _isConnected = false;
      _connectedDevice = null;
    } catch (e) {
      debugPrint('Error disconnecting bluetooth printer: $e');
    }
  }

  @override
  Future<bool> get isConnected async {
    if (!Platform.isAndroid) return false;
    try {
      return await _bluetooth.isConnected ?? false;
    } catch (e) {
      return false;
    }
  }

  @override
  Future<bool> print(Uint8List data) async {
    if (!Platform.isAndroid) return false;
    try {
      if (!await isConnected) return false;
      await _bluetooth.writeBytes(data);
      return true;
    } catch (e) {
      debugPrint('Error printing bluetooth: $e');
      disconnect();
      return false;
    }
  }
}
